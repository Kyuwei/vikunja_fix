<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VikunjaWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Vikunja">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Drag region for the extended title bar. -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Height="40"
                Padding="14,0,0,0"
                VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                <FontIcon Glyph="&#xE73E;" FontSize="14" />
                <TextBlock Text="Vikunja" VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Border>

        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
